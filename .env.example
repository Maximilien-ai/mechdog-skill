# MechDog Skill - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# Vision Model API Keys (for stretch goals)
# ============================================

# Nebius Token Factory API (recommended for vision)
# Get your API key from: https://tokenfactory.nebius.com
# Check available models in your Nebius dashboard
NEBIUS_API_KEY=your-nebius-api-key-here
NEBIUS_MODEL=Qwen/Qwen2-VL-7B-Instruct
# Note: Update NEBIUS_MODEL with the exact model ID from your Nebius account

# Alternative: Anthropic Claude (for vision)
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# MechDog Hardware Configuration (optional)
# ============================================

# MechDog IP address (if not using simulator)
# MECHDOG_IP=192.168.4.1  # AP mode
# MECHDOG_IP=192.168.1.100  # On your WiFi

# Simulator configuration (default: localhost:3000)
# SIMULATOR_PORT=3000
